generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String                @id @default(cuid())
  supabaseId    String?               @unique
  email         String                @unique
  name          String
  role          String                @default("CUSTOMER")
  avatar        String?
  companyId     String?
  walletBalance Float                 @default(0)
  loyaltyPoints Int                   @default(0)
  loyaltyTier   String                @default("Silver")
  isActive      Boolean               @default(true)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  passengers    Json?                 @default("[]")
  preferences   Json?                 @default("{\"sms\": false, \"meal\": \"Vegetarian\", \"seat\": \"Window\", \"email\": true, \"hotel\": \"Deluxe Suite\", \"carrier\": \"Indigo\", \"whatsapp\": true}")
  wishlist      Json?                 @default("[]")
  activities    Activity[]
  bookings      Booking[]
  cancellations CancellationRequest[]
  leads         Lead[]
  Redemption    Redemption[]
  company       Company?              @relation(fields: [companyId], references: [id])
}

model Company {
  id             String          @id @default(cuid())
  name           String
  domain         String?
  walletBalance  Float           @default(0)
  discountRate   Float           @default(0)
  isActive       Boolean         @default(true)
  approvedBy     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  corporateRates CorporateRate[]
  employees      User[]
}

model CorporateRate {
  id            String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  companyId     String
  category      String   @default("ALL")
  destination   String?
  discountType  String
  discountValue Float
  maxDiscount   Float?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  company       Company  @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model Lead {
  id              String     @id @default(cuid())
  destination     String
  travelerName    String
  travelerEmail   String
  travelerPhone   String?
  numberOfDays    Int        @default(5)
  inclusions      String     @default("[]")
  specificDemands String?
  notes           String?
  stage           String     @default("NEW")
  assignedTo      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  activities      Activity[]
  assignedUser    User?      @relation(fields: [assignedTo], references: [id])
}

model Activity {
  id          String   @id @default(cuid())
  leadId      String
  userId      String?
  type        String
  description String
  createdBy   String
  createdAt   DateTime @default(now())
  lead        Lead     @relation(fields: [leadId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])
}

model Package {
  id             String   @id @default(cuid())
  title          String
  duration       String
  price          Float
  originalPrice  Float?
  rating         Float    @default(4.5)
  provider       String   @default("GoRASA Direct")
  overview       String   @default("{}")
  itinerary      String   @default("{}")
  inclusions     String   @default("[]")
  exclusions     String   @default("[]")
  importantNotes String   @default("{}")
  images         String   @default("[]")
  status         String   @default("DRAFT")
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  category       String?  @default("STANDARD")
}

model PricingRule {
  id            String    @id @default(cuid())
  type          String
  destination   String?
  hotelName     String?
  markupPercent Float
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  name          String    @default("Unnamed Rule")
  category      String    @default("ALL")
  airlineCode   String?
  roomType      String?
  markupType    String    @default("PERCENT")
  markupValue   Float     @default(0)
  minPrice      Float?
  maxPrice      Float?
  priority      Int       @default(0)
  validFrom     DateTime? @db.Timestamptz(6)
  validTo       DateTime? @db.Timestamptz(6)
}

model Booking {
  id                String               @id @default(cuid())
  userId            String
  type              String
  itemName          String
  providerOrAirline String?
  price             Float
  originalPrice     Float?
  discountApplied   Float                @default(0)
  couponCodeUsed    String?
  status            String               @default("CONFIRMED")
  pnr               String?
  seatOrRoom        String?
  leadGuestPan      String?
  paxCount          Int                  @default(1)
  travelDates       String?
  bookedAt          DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  paymentStatus     String               @default("PENDING")
  confirmedAt       DateTime?            @db.Timestamptz(6)
  user              User                 @relation(fields: [userId], references: [id])
  cancellation      CancellationRequest?
  invoice           Invoice?
  payment           Payment?
}

model Payment {
  id            String    @id @default(cuid())
  bookingId     String    @unique
  amount        Float
  method        String
  status        String    @default("PENDING")
  phonepeId     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  gateway       String    @default("razorpay")
  orderId       String?
  paymentId     String?
  signature     String?
  failureReason String?
  refundedAt    DateTime? @db.Timestamptz(6)
  refundAmount  Float?
  metadata      Json?
  booking       Booking   @relation(fields: [bookingId], references: [id])
}

model Invoice {
  id        String   @id @default(cuid())
  bookingId String   @unique
  number    String   @unique
  url       String?
  issuedAt  DateTime @default(now())
  booking   Booking  @relation(fields: [bookingId], references: [id])
}

model CancellationRequest {
  id          String   @id @default(cuid())
  bookingId   String   @unique
  userId      String
  reason      String
  status      String   @default("PENDING")
  processedBy String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  booking     Booking  @relation(fields: [bookingId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

