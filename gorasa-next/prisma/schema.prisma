/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PreferenceOption {
  id        String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  category  String
  label     String
  value     String
  sortorder Int       @default(0)
  isactive  Boolean   @default(true)
  createdAt DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PromoCode {
  id              String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  code            String
  discountValue   Float
  type            String    @default("flat")
  description     String    @default("")
  minBookingValue Float     @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now()) @db.Timestamp(6)
  updatedAt       DateTime  @default(now()) @db.Timestamp(6)
  maxDiscount     Float?
  maxUses         Int?
  usedCount       Int       @default(0)
  applicableTo    String    @default("ALL")
  isFirstBooking  Boolean   @default(false)
  validFrom       DateTime? @db.Timestamptz(6)
  validTo         DateTime? @db.Timestamptz(6)
