# QA Environment Variables
# Copy to .env.local for QA testing
#
# WARNING: Do NOT commit actual credentials to git.
# Replace ALL <placeholders> with real values.
# See CONFIG-REFERENCE.md for where to find each secret.

# Supabase (Auth only) — anon key is safe to share, service role is NOT
NEXT_PUBLIC_SUPABASE_URL=https://isubgeemvhvhnhikxbjb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# Database Provider
DATABASE_PROVIDER=prisma

# NEON Database (QA) — rotate password immediately if leaked
DATABASE_URL=postgresql://neondb_owner:<your-neon-password>@<your-neon-host>/neondb?sslmode=require
DIRECT_URL=postgresql://neondb_owner:<your-neon-password>@<your-neon-direct-host>/neondb?sslmode=require

# TBO API credentials — these are test credentials, use env vars in CI/CD
TBO_USERNAME=RasaT
TBO_PASSWORD=<your-tbo-password>
TBO_HOTEL_USERNAME=TBOStaticAPITest
TBO_HOTEL_PASSWORD=<your-tbo-hotel-password>
TBO_ENDPOINT=http://api.tbotechnology.in/hotelapi_v7/hotelservice.svc

# Payment module
PAYMENT_MOCK=true
PAYMENT_GATEWAY=razorpay
NEXT_PUBLIC_APP_URL=http://localhost:3000
