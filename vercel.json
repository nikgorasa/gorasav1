{
  "version": 2,
  "builds": [
    {
      "src": "packages/backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "packages/frontend/dist/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/packages/backend/src/index.ts" },
    { "src": "/(.*)", "dest": "/packages/frontend/dist/$1" }
  ]
}
